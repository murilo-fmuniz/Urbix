# Exemplo de arquivo .env
# Copie este arquivo para .env e atualize com seus valores

# ==========================================
# DATABASE
# ==========================================

# SQLite (padrão - para desenvolvimento)
DATABASE_URL=sqlite:///./urbix.db

# PostgreSQL (para produção)
# DATABASE_URL=postgresql://urbix_user:urbix_password@localhost:5432/urbix

# Variáveis customizadas (se necessário)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=urbix_user
# DB_PASSWORD=urbix_password
# DB_NAME=urbix
